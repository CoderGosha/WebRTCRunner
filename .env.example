# Имя файла или абсолютный путь. Поиск: сначала COOKIES_LOCAL_DIR, затем COOKIES_VOLUME_DIR.
VK_COOKIES=vk-cookies.json
TELEMOST_COOKIES=cookies-yandex.json

# Каталоги внутри контейнера (compose: ./cookies → local, named volume → volume)
COOKIES_LOCAL_DIR=/app/cookies/local
COOKIES_VOLUME_DIR=/app/cookies/volume

# Подпись в каждом сообщении Telegram: «Сервер: …»
SERVER_NAME=

# Опционально: уведомления о join_link в Telegram (sendMessage)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Пауза перед первым запуском бинарников, сек (уведомление в Telegram — перед паузой)
PRESTART_SECONDS=3

# Запуск по платформам (1=вкл, 0=выкл); совместимо с WBStream (Wildberries).
VK_ENABLED=1
TELEMOST_ENABLED=1
WBSTREAM_ENABLED=1
